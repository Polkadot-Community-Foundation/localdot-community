# LocalDOT Web App Environment Variables — Summit stack
# Copy this to .env.local: cp .env.example .env.local
#
# All defaults already point at public Summit endpoints, so the only values you
# NEED to override are the contract addresses after a fresh deploy. Endpoints can
# stay as-is.

# Summit Asset Hub. Summit has NO hosted public eth-rpc — leave VITE_RPC_URL empty
# (it is stored for display only; contract I/O is host-routed over WSS).
VITE_RPC_URL=
VITE_CHAIN_ID=420420417
VITE_NETWORK_NAME=Summit Asset Hub

# Network key — selects the host-routed chain set from src/lib/host/networks.ts.
# Default: summit. Change at deploy time to target another network.
VITE_NETWORK=summit

# Contracts deployed on Summit Asset Hub (per-deployment — fill in after `pnpm run deploy`)
VITE_P2PMARKET_ADDRESS=
VITE_ZKPASSPORT_REGISTRY_ADDRESS=

# Summit IPFS Gateway (Bulletin-backed)
VITE_IPFS_GATEWAY=https://summit-ipfs.polkadot.io/ipfs/
