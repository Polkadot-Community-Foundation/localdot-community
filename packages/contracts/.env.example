# Deployment private key (required for the Hardhat deploy/verify/seed path on Summit)
PRIVATE_KEY=

# RPC URL for the Hardhat `summit` network. Summit has NO hosted public eth-rpc,
# so run a local revive eth-rpc adapter (→ wss://summit-asset-hub-rpc.polkadot.io)
# and point this at it. Defaults to http://localhost:8545 if unset.
SUMMIT_RPC_URL=http://localhost:8545

# Enable gas reporting in tests
REPORT_GAS=false

# Seed accounts for 'pnpm contracts:seed'
AGENT1_KEY=
AGENT2_KEY=
PROVIDER1_KEY=
PROVIDER2_KEY=
